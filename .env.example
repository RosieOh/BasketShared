# =============================================================================
# S3-SyncBridge — Environment Configuration
# Copy to `.env` and adjust. NEVER commit the real `.env`.
# =============================================================================

# ---------- General ----------
NODE_ENV=development
TZ=UTC

# ---------- NestJS Orchestrator ----------
# APP_PORT is the INTERNAL container port; APP_HOST_PORT is what's published on
# the host. Change the *_HOST_PORT values if a port is already busy on your host.
APP_PORT=3000
APP_HOST_PORT=3000
# Shared secret SFTPGo sends in the `X-SyncBridge-Token` header. Rotate in prod.
WEBHOOK_SECRET=change-me-super-secret-webhook-token
# Log level: fatal|error|warn|info|debug|trace|silent.
LOG_LEVEL=info

# ---------- Auth (JWT + RBAC) ----------
# HS256 signing secret — use a long random value in production.
JWT_SECRET=change-me-jwt-signing-secret
JWT_EXPIRES_IN=1h
# Bootstrap admin, seeded on first start if the users table is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
# Pretty-print logs? Keep false for the container (JSON); pino-pretty is dev-only.
LOG_PRETTY=false
# Max attempts for a single file transfer before it is marked FAILED.
TRANSFER_MAX_ATTEMPTS=3
# Base backoff (ms) between transfer retries; grows exponentially per attempt.
TRANSFER_RETRY_BACKOFF_MS=1000
# Absolute base dir (inside the NestJS container) under which uploaded files
# live. Used to sandbox the path supplied by the webhook (anti path-traversal).
INGESTION_DATA_ROOT=/srv/sftpgo/data
# Max file transfers processed concurrently (backpressure for upload spikes).
WORKER_CONCURRENCY=5

# ---------- Rate limiting & payload size ----------
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
MAX_PAYLOAD_SIZE_KB=1024

# ---------- Processing pipeline ----------
# Reject files larger than this many MB (0 = no limit).
MAX_FILE_SIZE_MB=1024
# Enable ClamAV scan step. If true, start the stack with: --profile av
AV_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ---------- Object encryption (envelope, AES-256-GCM) ----------
# When true, files are encrypted client-side before upload. KEK = base64(32 bytes).
# Generate: openssl rand -base64 32
ENCRYPTION_ENABLED=false
ENCRYPTION_KEK=

# ---------- Failure alerting ----------
# Post FAILED-transfer alerts to a Slack-compatible webhook. Empty = log only.
ALERTS_ENABLED=false
ALERT_WEBHOOK_URL=

# ---------- Multi-destination routing ----------
# JSON array of rules (first match wins); empty = everything to S3_BUCKET.
# Each rule: {"match":{"username"?,"extension"?,"pathPrefix"?},"bucket"?,"prefix"?}
ROUTING_RULES=

# ---------- Multi-tenancy ----------
# Map SFTP usernames to tenant ids (JSON); unmapped users fall back to DEFAULT_TENANT.
DEFAULT_TENANT=default
TENANT_MAP=

# ---------- Per-tenant quotas ----------
# 0 = unlimited. TENANT_QUOTAS (JSON) overrides per tenant.
# e.g. {"acme":{"maxBytes":1048576,"maxObjects":100}}
QUOTA_DEFAULT_MAX_BYTES=0
QUOTA_DEFAULT_MAX_OBJECTS=0
TENANT_QUOTAS=

# ---------- Kafka event backbone (profile: streaming) ----------
# Publish domain events to Kafka; Debezium streams DB changes (CDC) too.
KAFKA_ENABLED=false
KAFKA_BROKERS=kafka:9092
KAFKA_EVENTS_TOPIC=syncbridge.events

# ---------- Tracing (OpenTelemetry) ----------
# Enable to export traces to the Jaeger collector (start with --profile monitoring).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=s3-syncbridge

# ---------- Stuck-transfer recovery sweeper ----------
# Periodically re-drives PENDING/PROCESSING rows abandoned by a crash/restart.
RECOVERY_ENABLED=true
# A row idle longer than this (ms) is treated as stuck. Default 15 min.
RECOVERY_STALE_MS=900000
# Max rows re-driven per sweep.
RECOVERY_BATCH_SIZE=50

# ---------- Data lifecycle ----------
# Purge terminal audit rows older than N days (0 = keep forever).
AUDIT_RETENTION_DAYS=0
# Expire bucket objects after N days via S3 lifecycle/ILM (0 = disabled).
S3_LIFECYCLE_DAYS=0

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_USER=syncbridge
# Non-superuser role the app connects as (so Row-Level Security applies).
# Created by postgres-init/10-app-role.sh on a fresh volume.
APP_DB_USER=syncbridge_app
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=syncbridge
# Set true only for throwaway local dev. Prod MUST use migrations.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ---------- Redis (BullMQ queue) ----------
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty for no auth (local). Set a strong password in production.
REDIS_PASSWORD=
REDIS_HOST_PORT=6379

# ---------- Object Storage (MinIO / AWS S3) ----------
# For MinIO point at the in-network service; for AWS leave S3_ENDPOINT empty.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=ingested-files
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio-password
# MinIO needs path-style addressing; AWS S3 uses virtual-hosted (set false).
S3_FORCE_PATH_STYLE=true
# Multipart part size in MB for large-file streaming uploads.
S3_UPLOAD_PART_SIZE_MB=8
S3_UPLOAD_CONCURRENCY=4

# ---------- MinIO server (docker-compose only) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- SFTPGo server (docker-compose only) ----------
SFTPGO_SFTP_PORT=2022
SFTPGO_HTTP_PORT=8080
SFTPGO_ADMIN_USER=admin
SFTPGO_ADMIN_PASSWORD=change-me-sftpgo-admin
