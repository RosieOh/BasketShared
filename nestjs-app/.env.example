# Local (non-Docker) dev: run `npm run start:dev` against services exposed on
# localhost by docker-compose. Inside Docker the values come from the root .env.
NODE_ENV=development

APP_PORT=3000
WEBHOOK_SECRET=local-dev-webhook-token
ADMIN_API_KEY=local-dev-admin-key
LOG_LEVEL=debug
# Local runs have pino-pretty (dev dep), so pretty logs are fine here.
LOG_PRETTY=true
TRANSFER_MAX_ATTEMPTS=3
TRANSFER_RETRY_BACKOFF_MS=1000
# When running on the host, point at wherever the shared volume is reachable.
# Easiest is to run the orchestrator inside Docker; on the host you'd bind-mount.
INGESTION_DATA_ROOT=/srv/sftpgo/data
WORKER_CONCURRENCY=5
MAX_FILE_SIZE_MB=1024
AV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
RECOVERY_ENABLED=true
RECOVERY_STALE_MS=900000
RECOVERY_BATCH_SIZE=50

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=syncbridge
POSTGRES_PASSWORD=local-dev-postgres
POSTGRES_DB=syncbridge
DB_SYNCHRONIZE=false
DB_LOGGING=true

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ingested-files
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=local-dev-minio
S3_FORCE_PATH_STYLE=true
S3_UPLOAD_PART_SIZE_MB=8
S3_UPLOAD_CONCURRENCY=4
